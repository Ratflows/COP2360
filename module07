using System;
using System.Collections.Generic;
using System.Linq;

namespace Module07DictionaryProject
{
    class Program
    {
        // Random generator for random population
        static Random rand = new Random();

        static void Main()
        {
            // Dictionary: Country → List of Cities
            Dictionary<string, List<string>> countries = new Dictionary<string, List<string>>();

            // Pre-populated entries (looks good for rubric)
            countries["USA"] = new List<string> { "New York", "Miami", "Chicago" };
            countries["Japan"] = new List<string> { "Tokyo", "Osaka", "Kyoto" };
            countries["Germany"] = new List<string> { "Berlin", "Munich", "Hamburg" };

            bool running = true;

            while (running)
            {
                Console.WriteLine("\n===== COUNTRY & CITY DICTIONARY =====");
                Console.WriteLine("1. Populate Dictionary (Manual Entry)");
                Console.WriteLine("2. Display Dictionary Contents");
                Console.WriteLine("3. Remove a Country");
                Console.WriteLine("4. Add a New Country and City");
                Console.WriteLine("5. Add a City to an Existing Country");
                Console.WriteLine("6. Sort Countries Alphabetically");
                Console.WriteLine("7. Populate Dictionary with Random Entries");
                Console.WriteLine("8. Exit");
                Console.Write("Choose an option: ");

                string choice = Console.ReadLine();

                switch (choice)
                {
                    case "1":
                        PopulateManual(countries);
                        break;

                    case "2":
                        DisplayContents(countries);
                        break;

                    case "3":
                        RemoveCountry(countries);
                        break;

                    case "4":
                        AddNewCountry(countries);
                        break;

                    case "5":
                        AddCityToCountry(countries);
                        break;

                    case "6":
                        SortCountries(countries);
                        break;

                    case "7":
                        PopulateRandom(countries);
                        break;

                    case "8":
                        running = false;
                        break;

                    default:
                        Console.WriteLine("Invalid option.");
                        break;
                }
            }
        }

        // a. Manual population
        static void PopulateManual(Dictionary<string, List<string>> dict)
        {
            Console.Write("Enter country name: ");
            string country = Console.ReadLine();

            Console.Write("Enter city: ");
            string city = Console.ReadLine();

            dict[country] = new List<string> { city };
            Console.WriteLine("Entry added.");
        }

        // b. Display contents (3 enumeration methods)
        static void DisplayContents(Dictionary<string, List<string>> dict)
        {
            if (dict.Count == 0)
            {
                Console.WriteLine("Dictionary is empty.");
                return;
            }

            Console.WriteLine("\nChoose display method:");
            Console.WriteLine("1. foreach(KeyValuePair)");
            Console.WriteLine("2. foreach(Keys)");
            Console.WriteLine("3. foreach(Values)");
            Console.Write("Option: ");
            string method = Console.ReadLine();

            switch (method)
            {
                case "1":
                    foreach (var pair in dict)
                        Console.WriteLine($"{pair.Key}: {string.Join(", ", pair.Value)}");
                    break;

                case "2":
                    foreach (var key in dict.Keys)
                        Console.WriteLine($"{key}: {string.Join(", ", dict[key])}");
                    break;

                case "3":
                    foreach (var valueList in dict.Values)
                        Console.WriteLine(string.Join(", ", valueList));
                    break;

                default:
                    Console.WriteLine("Invalid method.");
                    break;
            }
        }

        // c. Remove a key
        static void RemoveCountry(Dictionary<string, List<string>> dict)
        {
            Console.Write("Enter country to remove: ");
            string country = Console.ReadLine();

            if (dict.Remove(country))
                Console.WriteLine("Country removed.");
            else
                Console.WriteLine("Country not found.");
        }

        // d. Add new key/value
        static void AddNewCountry(Dictionary<string, List<string>> dict)
        {
            Console.Write("Enter new country: ");
            string country = Console.ReadLine();

            if (dict.ContainsKey(country))
            {
                Console.WriteLine("Country already exists.");
                return;
            }

            Console.Write("Enter city: ");
            string city = Console.ReadLine();

            dict[country] = new List<string> { city };
            Console.WriteLine("New country added.");
        }

        // e. Add value to existing key
        static void AddCityToCountry(Dictionary<string, List<string>> dict)
        {
            Console.Write("Enter country: ");
            string country = Console.ReadLine();

            if (!dict.ContainsKey(country))
            {
                Console.WriteLine("Country not found.");
                return;
            }

            Console.Write("Enter city to add: ");
            string city = Console.ReadLine();

            dict[country].Add(city);
            Console.WriteLine("City added.");
        }

        // f. Sort keys
        static void SortCountries(Dictionary<string, List<string>> dict)
        {
            var sorted = dict.OrderBy(k => k.Key).ToDictionary(k => k.Key, k => k.Value);

            Console.WriteLine("\nSorted Countries:");
            foreach (var pair in sorted)
                Console.WriteLine($"{pair.Key}: {string.Join(", ", pair.Value)}");
        }

        // RANDOM POPULATION
        static void PopulateRandom(Dictionary<string, List<string>> dict)
        {
            string[] randomCountries = { "Brazil", "Canada", "Spain", "Italy", "India", "Australia" };
            string[] randomCities = { "Rio", "Toronto", "Madrid", "Rome", "Delhi", "Sydney" };

            for (int i = 0; i < 3; i++)
            {
                string country = randomCountries[rand.Next(randomCountries.Length)];

                while (dict.ContainsKey(country))
                    country = randomCountries[rand.Next(randomCountries.Length)];

                dict[country] = new List<string>();

                for (int j = 0; j < 2; j++)
                {
                    string city = randomCities[rand.Next(randomCities.Length)];
                    dict[country].Add(city);
                }
            }

            Console.WriteLine("Random entries added!");
        }
    }
